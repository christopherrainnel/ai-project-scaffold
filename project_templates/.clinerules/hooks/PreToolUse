#!/usr/bin/env python3
import json
import sys

BLOCKED_COMMAND_FRAGMENTS = [
    "git reset --hard",
    "git checkout --",
    "git clean -fd",
    "rm -rf",
    "remove-item -recurse -force",
    "del /f",
]


def emit(cancel, context="", error=""):
    print(json.dumps({"cancel": cancel, "contextModification": context, "errorMessage": error}))
    raise SystemExit(0)


def walk_strings(value):
    if isinstance(value, str):
        yield value
    elif isinstance(value, dict):
        for nested in value.values():
            yield from walk_strings(nested)
    elif isinstance(value, list):
        for nested in value:
            yield from walk_strings(nested)


try:
    payload = json.load(sys.stdin)
except Exception:
    emit(False)

pre = payload.get("preToolUse") or {}
tool_name = (pre.get("toolName") or pre.get("tool") or "").strip()
parameters = pre.get("parameters") or {}
strings = list(walk_strings(parameters))
combined = " ".join(strings).lower()


def is_env_path(text):
    normalized = text.replace("\\", "/").lower()
    if normalized.endswith(".env.example") or "/.env.example" in normalized:
        return False
    return (
        normalized == ".env"
        or normalized.endswith("/.env")
        or "/.env." in normalized
        or normalized.endswith(".env")
    )


if tool_name in {"Read", "Edit", "MultiEdit", "Write", "read_file", "write_to_file", "replace_in_file"}:
    if any(is_env_path(value) for value in strings):
        emit(True, error="Reading or editing .env files is blocked by workspace policy. Update .env.example instead.")

if tool_name in {"Bash", "execute_command"}:
    if any(fragment in combined for fragment in BLOCKED_COMMAND_FRAGMENTS):
        emit(True, error="This destructive command is blocked by workspace policy. Ask the user explicitly before retrying.")

emit(
    False,
    context=(
        "SECURITY: Never read or modify .env. Ask before destructive commands. "
        "Before relying on prior local assumptions, confirm the Workstation Context Check."
    ),
)
