# Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is excluded by .gitignore.

# ── Application ──────────────────────────────────────────
# NODE_ENV=development
# PORT=3000

# ── Secrets ──────────────────────────────────────────────
# API_KEY=
# DATABASE_URL=
# AUTH_SECRET=

# ── Third-Party Services ─────────────────────────────────
# STRIPE_KEY=
# SENDGRID_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=


# ── Entitlement Keys (optional) ───────────────────────
# FREE_LICENSE_KEYS=
# PRO_LICENSE_KEYS=

